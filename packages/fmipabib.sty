% fmipabib.sty
% Paket Bibliografi Khusus FMIPA UGM
% Berdasarkan Panduan Penulisan Terbaru FMIPA UGM

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fmipabib}[2026/05/03 v1.3 FMIPA UGM Bibliography Style]

% --- 1. LOAD PAKET BIBLATEX ---
\RequirePackage[
    backend=biber,
    style=ext-authoryear, % Sistem Harvard (Nama-Tahun)
    maxcitenames=2,       % Di teks: max 2 nama. Jika >2 jadi et al
    mincitenames=1,
    maxbibnames=99,       % Di Daftar Pustaka: Tulis SEMUA nama (Dilarang et al.)
    giveninits=true,      % Nama depan disingkat jadi inisial (Ross, S.L.)
    uniquename=init,      % Gunakan inisial untuk membedakan nama yang sama
    dashed=false,         % Jangan ganti nama pengarang berulang dengan garis
    sorting=nyt,          % Urutan: Name, Year, Title
    date=year,            % Hanya tampilkan tahun
    urldate=long,         % Format tanggal akses panjang
    isbn=false,           % Tidak perlu menampilkan ISBN
    doi=true              % Tampilkan DOI jika ada (wajib per ketentuan terbaru)
]{biblatex}

% Make \cite behave like \parencite (add parentheses automatically)
% Sehingga \cite{key} menghasilkan (Author, Year) bukan Author, Year
\let\cite\parencite

% --- 2. PENGATURAN BAHASA & ISTILAH ---

% Biblatex tidak mengenali 'bahasa', fallback ke 'english'.
% Override string English agar sesuai format FMIPA UGM terbaru.
\DefineBibliographyStrings{english}{%
    andothers = {\mkbibemph{et\addabbrvspace al\adddot}},%
    and       = {\&},%
    pages     = {},%
    page      = {},%
    edition   = {edisi ke},%
    byeditor  = {ed.}%
}

% Format DOI: tampilkan sebagai "doi: https://doi.org/..."
\DeclareFieldFormat{doi}{doi:\space\url{https://doi.org/#1}}

% Format edisi: "edisi ke 2" bukan "2nd ed."
\DeclareFieldFormat{edition}{edisi ke\space#1}

% --- 3. FORMAT DAFTAR PUSTAKA ---

% A. Spasi: Tunggal di dalam item, 1.5 antar item
\setlength{\bibitemsep}{\baselineskip} % Jarak antar pustaka ~1.5 spasi
\AtBeginBibliography{\singlespacing}   % Paksa spasi tunggal di dalam item

% B. Format Nama: Nama Belakang, Inisial.
\DeclareNameAlias{sortname}{family-given}
\DeclareNameAlias{default}{family-given}
\DeclareNameAlias{author}{family-given}

% C. Jika tidak ada penulis, tampilkan "Anonim"
% Override macro author agar menampilkan "Anonim" jika author kosong
\renewbibmacro*{author}{%
    \ifnameundef{author}
    {\printtext{Anonim}}
    {\printnames{author}}%
}

% D. Tahun harus muncul setelah nama penulis TANPA kurung
% ext-authoryear style menampilkan tahun dalam kurung: Author (2001)
% Override: hapus kurung dari tahun di daftar pustaka
% Redefine \mkbibbrackets to not add brackets in bibliography
\AtBeginBibliography{%
    \renewcommand{\mkbibbrackets}[1]{##1}%
}

% E. Tanda Baca: koma sebagai pemisah antar elemen
\renewcommand*{\newunitpunct}{\addcomma\space}

% --- 4. FORMAT JUDUL & TIPE DOKUMEN ---

% 1. Buku: Judul Miring
\DeclareFieldFormat[book]{title}{\mkbibemph{#1}}
\DeclareFieldFormat[mvbook]{title}{\mkbibemph{#1}}

% 2. Artikel Jurnal: Nama Jurnal Miring, Judul Artikel Tegak
\DeclareFieldFormat[article]{journaltitle}{\mkbibemph{#1}}
\DeclareFieldFormat[article]{title}{#1}

% 3. Prosiding: Judul Prosiding Miring
\DeclareFieldFormat[inproceedings]{booktitle}{\mkbibemph{#1}}
\DeclareFieldFormat[inproceedings]{title}{#1}

% 4. Skripsi/Tesis/Disertasi: Tipe dokumen Miring
\DeclareFieldFormat[thesis]{title}{#1}
\DeclareFieldFormat[thesis]{type}{\mkbibemph{#1}}

% 5. Artikel dalam Buku: Judul Artikel Miring & Judul Buku Miring
\DeclareFieldFormat[incollection]{title}{\mkbibemph{#1}}
\DeclareFieldFormat[incollection]{booktitle}{\mkbibemph{#1}}

% 6. Internet: URL Miring
\DeclareFieldFormat{url}{\mkbibemph{#1}}
\DeclareFieldFormat{urldate}{diakses tanggal #1}

% 7. Laporan Penelitian: Tipe Miring
\DeclareFieldFormat[report]{type}{\mkbibemph{#1}}
\DeclareFieldFormat[report]{title}{#1}

% 8. Paten: Judul Miring
\DeclareFieldFormat[patent]{title}{\mkbibemph{#1}}
\DeclareFieldFormat[patent]{number}{No.\ #1}

% 9. Buku Terjemahan: format penerjemah
\renewbibmacro*{bytranslator+others}{%
    \ifnameundef{translator}
    {}
    {\printtext{(diterjemahkan oleh:\addspace}%
     \printnames{translator}%
     \printtext{)}}%
    \newunit
}

% --- 5. MAKRO PENYUSUNAN ELEMEN ---

% Menghapus "In:"
\renewbibmacro*{in:}{}

% Format URL: URL (miring), diakses tanggal...
\renewbibmacro*{url+urldate}{%
    \printfield{url}%
    \setunit*{\addcomma\space}%
    \printurldate}

% Mengatur urutan Jurnal: nama majalah, nomor, volume dan halaman
\renewbibmacro*{journal+issuetitle}{%
    \usebibmacro{journal}%
    \setunit*{\addcomma\space}%
    \iffieldundef{series}
    {}
    {\newunit
        \printfield{series}%
        \setunit{\addcomma\space}}%
    \printfield{number}%
    \setunit*{\addcomma\space}%
    \printfield{volume}%
    \setunit{\addcomma\space}%
    \printfield{eid}%
    \newunit}

\endinput
